{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_export_vars,
    warn_unused_import
]}.

{deps, [
    {cowboy, "2.12.0"},
    {jsx, "3.1.0"}
]}.

{profiles, [
    {test, [
        {deps, [
            {meck, "0.9.2"}
        ]},
        {erl_opts, [nowarn_export_all]}
    ]},
    {prod, [
        {relx, [
            {mode, prod},
            {include_erts, true},
            {include_src, false}
        ]}
    ]}
]}.

{dialyzer, [
    {warnings, [
        unknown,
        unmatched_returns,
        error_handling,
        underspecs
    ]},
    {plt_apps, top_level_deps},
    {plt_extra_apps, [ssl, crypto, public_key]}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls,
    deprecated_functions
]}.

{cover_enabled, true}.
{cover_opts, [verbose]}.

%% NIF compilation hooks - use CMake via build.sh for cross-platform support
{pre_hooks, [
    {"(linux|darwin|freebsd|solaris)", compile, "c_src/build.sh"},
    {"win32", compile, "cd c_src && cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Release && cmake --build build --config Release"}
]}.

{post_hooks, [
    {"(linux|darwin|freebsd|solaris)", clean, "c_src/build.sh clean"}
]}.

{relx, [
    {release, {derp, "0.1.0"}, [
        derp,
        sasl
    ]},
    {mode, dev},
    {include_erts, false},
    {extended_start_script, true},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"}
]}.

%% Escript configuration for test client
{escript_name, derp_test_client}.
{escript_main_app, derp}.
{escript_emu_args, "%%! -escript main derp_test_client\n"}.
%% Don't include ssl/crypto/public_key - they have NIFs that must come from system Erlang
{escript_incl_apps, [derp, cowboy, ranch, cowlib, jsx]}.

{hex, [
    {doc, #{provider => ex_doc}}
]}.

{project_plugins, [rebar3_hex, rebar3_ex_doc]}.

{ex_doc, [
    {extras, [
        {"README.md", #{title => "Overview"}},
        {"guides/installation.md", #{title => "Installation"}},
        {"guides/quickstart.md", #{title => "Quick Start"}},
        {"guides/server.md", #{title => "Server Configuration"}},
        {"guides/client.md", #{title => "Client Usage"}},
        {"guides/tls.md", #{title => "TLS with BoringSSL"}},
        {"guides/docker.md", #{title => "Docker Deployment"}},
        {"guides/protocol.md", #{title => "Protocol Reference"}},
        {"CHANGELOG.md", #{title => "Changelog"}},
        {"LICENSE", #{title => "License"}}
    ]},
    {main, "README.md"},
    {source_url, "https://github.com/benoitc/erlang-derp"},
    {groups_for_extras, [
        {<<"Getting Started">>, [<<"guides/installation.md">>, <<"guides/quickstart.md">>]},
        {<<"Guides">>, [<<"guides/server.md">>, <<"guides/client.md">>, <<"guides/tls.md">>, <<"guides/docker.md">>]},
        {<<"Reference">>, [<<"guides/protocol.md">>]}
    ]}
]}.
